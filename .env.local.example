# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend
RESEND_API_KEY=your_resend_api_key

# OpenAI (used by Ops Copilot)
OPENAI_API_KEY=your_openai_api_key

# Twilio (used by Ops Copilot staff alert SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Google Analytics (GA4 measurement ID, e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# App (set to your production URL on Render so Table QR links show correctly in admin)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
